{
  "name": "antigravity-monorepo",
  "private": true,
  "description": "Antigravity SaaS Platform Monorepo",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "db:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=backend/prisma/schema.prisma",
    "build:backend": "npm run db:generate && npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "npm run start:prod --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "start": "npm run start:backend",
    "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "prisma": "5.22.0"
  }
}
