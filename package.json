{
  "name": "antigravity-monorepo",
  "private": true,
  "description": "Antigravity SaaS Platform Monorepo",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:push": "npm run db:push --workspace=backend",
    "build:backend": "npm run db:generate && npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start:backend": "npm run start:prod --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "start": "npm run start:backend",
    "heroku-postbuild": "npm run build"
  }
}